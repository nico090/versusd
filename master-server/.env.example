# Copy to .env and adjust. Loaded by app/config.py (pydantic-settings).

# Secret used to sign JWT access tokens. CHANGE THIS in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-insecure-change-me

# Shared secret game servers present (X-Server-Secret header) to call the
# privileged /servers/* and /stats/match-result endpoints. CHANGE THIS in prod.
SERVER_SHARED_SECRET=dev-insecure-change-me

# Set to false ONLY for local dev to allow the insecure placeholders above.
# In production leave it true (the app refuses to start with default secrets).
REQUIRE_SECURE_SECRETS=true

# Minutes a JWT access token stays valid.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MongoDB connection string and database name.
# Local dev: mongodb://localhost:27017 ; docker-compose: mongodb://mongo:27017
MONGO_URL=mongodb://localhost:27017
DB_NAME=versused

# Seconds without a heartbeat before a lobby is considered dead.
LOBBY_TTL_SECONDS=45
# Seconds without a heartbeat before a server doc is pruned (crash recovery).
SERVER_TTL_SECONDS=60
# Minutes a join_token stays valid after being issued.
JOIN_TOKEN_EXPIRE_MINUTES=10

# ── On-demand dedicated game-server spawning ──────────────────────────────────
# Public IP players connect to (reported to the client on lobby creation).
VPS_PUBLIC_IP=127.0.0.1
# Docker image name for spawned game servers (build with Dockerfile.gameserver).
GAME_SERVER_IMAGE=versused-game-server
# UDP port range opened on the VPS firewall (one port per concurrent match).
GAME_SERVER_PORT_START=9000
GAME_SERVER_PORT_END=9999
# Docker network spawned containers join (must reach the master server).
DOCKER_NETWORK=master-server_versused
# URL spawned containers use to reach the master server.
MASTER_SERVER_INTERNAL_URL=http://master-server:8000
